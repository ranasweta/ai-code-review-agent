# ---------------------------------------------------------------------------
# Environment variable TEMPLATE.
# ---------------------------------------------------------------------------
# Copy this file to ".env" (which is git-ignored) and paste in your real keys.
#   cp .env.example .env       # macOS / Linux
#   copy .env.example .env     # Windows
#
# NEVER commit the real .env file — it contains secrets.
# All three services have a free tier; see the guide's "Before You Start".
# ---------------------------------------------------------------------------

# GitHub Personal Access Token — needs "public_repo" scope (read only).
# Get it: github.com -> Settings -> Developer Settings -> Personal Access Tokens
GITHUB_TOKEN=ghp_your_token_here

# Google Gemini API key (default LLM provider).
# Get it: aistudio.google.com -> Get API Key
GEMINI_API_KEY=your_gemini_key_here

# Groq API key (backup LLM provider, runs Llama 3).
# Get it: console.groq.com -> API Keys
GROQ_API_KEY=your_groq_key_here

# Optional overrides (defaults shown). Uncomment to change.
# DEFAULT_LLM_PROVIDER=gemini
# MAX_RETRIES=3
# TEMPERATURE=0.1
