# ---------------------------------------------------------------------------
# Streamlit secrets TEMPLATE (Day 7 — deployment).
# ---------------------------------------------------------------------------
# LOCAL dev: copy this to ".streamlit/secrets.toml" (git-ignored) if you prefer
# secrets over a .env file. Either source works — config.py reads env first,
# then falls back to these.
#
# STREAMLIT CLOUD: do NOT commit a real secrets.toml. Instead paste these
# key/value pairs into the app dashboard under Settings -> Secrets.
#
# NEVER commit the real secrets.toml — it contains live keys (it's in .gitignore).
# ---------------------------------------------------------------------------

GITHUB_TOKEN = "ghp_your_token_here"
GEMINI_API_KEY = "your_gemini_key_here"
GROQ_API_KEY = "your_groq_key_here"

# Optional overrides (defaults shown):
# DEFAULT_LLM_PROVIDER = "gemini"
# MAX_RETRIES = "3"
# TEMPERATURE = "0.1"
